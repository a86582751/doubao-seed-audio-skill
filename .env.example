# Volcano Speech/OpenSpeech API key for Seed Audio.
# Source: https://console.volcengine.com/speech/new/setting/apikeys?projectName=default
SEED_AUDIO_API_KEY=your_volcano_speech_api_key
SEED_AUDIO_BASE_URL=https://openspeech.bytedance.com
SEED_AUDIO_MODEL=seed-audio-1.0
SEED_AUDIO_FORMAT=mp3
SEED_AUDIO_SAMPLE_RATE=24000
